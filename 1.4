// Vogal ou Consoante: Verifica se uma letra armazenada numa variável é uma vogal (a, e, i, o, u) ou uma consoante.
let letra = prompt("digite uma letra: ");

if(letra == "a" || letra == "e" || letra == "i" || letra == "o" || letra == "u"){
    console.log(" a letra é uma vogal\n\n");
}else{
    console.log("a letra é uma consoante\n\n");
}

