// Dia da Semana: Cria uma variável com um número de 1 a 7. Se for 6 ou 7, imprime "É fim de semana!", senão imprime "É dia útil!".
let dia = Number(prompt("digite um numero de 1 a 7: "));

if(dia == 6 || dia == 7){
    console.log("É fim de semanaaaaa!\n\n\n");
}else if(dia > 7 || dia < 1){
    console.log("digite um dia de 1 a 7 por favor!\n\n\n");
}else{
    console.log("É dia util!\n\n\n");
}







